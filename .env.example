# ============================================================================
# Cymatyx Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in the values you need.
# Do NOT commit your .env file to version control.
#
# NOTE: Environment variables take priority over API keys stored in the
# browser's local storage. If a key is set here, it will override any
# key the user has saved in the app's settings UI.
# ============================================================================

# ----------------------------------------------------------------------------
# Build-time Variables (injected via vite.config.ts define)
# ----------------------------------------------------------------------------

# Google Gemini API key — used at build time via vite.config.ts define block.
# Exposed as process.env.API_KEY and process.env.GEMINI_API_KEY in client code.
GEMINI_API_KEY=

# ----------------------------------------------------------------------------
# Client-side Variables (VITE_ prefix — available via import.meta.env)
# ----------------------------------------------------------------------------

# OpenAI API key (GPT-4, GPT-3.5, etc.)
VITE_OPENAI_API_KEY=

# Anthropic API key (Claude models)
VITE_ANTHROPIC_API_KEY=

# OpenRouter API key (unified gateway to multiple LLM providers)
VITE_OPENROUTER_API_KEY=

# Venice AI API key
VITE_VENICE_API_KEY=

# Groq API key (fast inference for open-source models)
VITE_GROQ_API_KEY=

# Mistral AI API key
VITE_MISTRAL_API_KEY=

# Cohere API key (Command, Embed, etc.)
VITE_COHERE_API_KEY=

# Together AI API key (open-source model hosting)
VITE_TOGETHER_API_KEY=

# Perplexity AI API key (search-augmented models)
VITE_PERPLEXITY_API_KEY=

# xAI API key (Grok models)
VITE_XAI_API_KEY=

# DeepSeek API key
VITE_DEEPSEEK_API_KEY=

# Nebius API key
VITE_NEBIUS_API_KEY=

# Google Gemini Live API key (real-time/streaming Gemini features)
VITE_GEMINI_LIVE_API_KEY=
